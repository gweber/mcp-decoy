{
  "name": "mcpdecoy",
  "version": "1.0.0",
  "description": "MCP server decoy for deception-based threat detection",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dashboard:dev": "cd dashboard && npm run dev",
    "dashboard:build": "cd dashboard && npm run build"
  },
  "keywords": [
    "mcp",
    "decoy",
    "deception",
    "security",
    "honeypot"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
